# Use a flat (hoisted) node_modules instead of pnpm's default isolated/symlinked layout.
# Tailwind 4's Rust engine (@tailwindcss/oxide) resolves its platform-specific native optional
# dependency (e.g. @tailwindcss/oxide-linux-x64-gnu) by walking node_modules; the isolated layout
# can leave that binary unlinked on Linux (Railway/Nixpacks), causing
# "@tailwindcss/oxide: Cannot find native binding" during `vite build`. Hoisting makes the binary
# discoverable. (Local macOS builds work either way; only the Linux deploy reproduces the failure.)
node-linker=hoisted
