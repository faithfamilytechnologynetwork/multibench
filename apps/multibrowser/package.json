{
  "name": "multibrowser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browse & explore MultiBench traditions — a client-side SPA reading the corpus live from GitHub.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "start": "serve -s dist -l ${PORT:-4173}",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@tanstack/query-sync-storage-persister": "^5.91.0",
    "@tanstack/react-query": "^5.91.1",
    "@tanstack/react-query-persist-client": "^5.91.0",
    "@tanstack/react-router": "^1.141.1",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.546.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "serve": "^14.2.4",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "vitest": "^3.2.1"
  }
}
