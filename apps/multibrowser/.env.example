# multibrowser is a PURE client-side SPA. It reads the tradition corpus from GitHub at runtime
# in the browser — there is NO server and NO secret/token (a client app can't keep one safe).
# All config is build-time (Vite `VITE_*`), baked into the static bundle.

# Which repo/ref to read traditions/ from.
VITE_MULTIBENCH_REPO=faithfamilytechnologynetwork/multibench
VITE_MULTIBENCH_REF=main

# How often the browser polls GitHub for a new commit SHA (ms). The default (5 min) is
# deliberately conservative: GitHub's unauthenticated limit is 60 req/hr per IP and may be
# SHARED across users behind one NAT, so we poll gently and rely on focus/reconnect refetch
# for snappier updates. Only the SHA poll + the one tree call are on-budget; all file content
# is fetched via raw.githubusercontent.com, which is off the API rate budget.
VITE_SHA_POLL_MS=300000
